{
  "name": "@fileforge/react-print",
  "version": "0.1.150",
  "description": "Fileforge components for JavaScript React",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "require": "./dist/client/index.js",
      "import": "./dist/client/index.mjs"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "require": "./dist/server/index.js",
      "import": "./dist/server/index.mjs"
    },
    "./mdx": {
      "types": "./dist/mdx.d.ts",
      "require": "./dist/mdx.js",
      "import": "./dist/mdx.mjs"
    },
    "./dist/*.css": {
      "import": "./dist/*.css",
      "require": "./dist/*.css"
    }
  },
  "scripts": {
    "build": "patch-package && tsup --external @fileforge/react-print --clean && tsup --external @fileforge/react-print",
    "test": "vitest --browser chrome",
    "dev": "(cd ./docs && mintlify dev --watch)",
    "build-components": "npm run build && tsx ./docgen/index.ts",
    "prune-docs": "tsx ./docgen/prune.ts",
    "build-components-commit": "npm run build-components && npm run prune-docs",
    "lint": "biome lint",
    "format": "biome format",
    "check": "biome check"
  },
  "pre-commit": [
    "build-components-commit"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@chakra-ui/react": "^2.10.9",
    "@esbuild-plugins/node-modules-polyfill": "^0.2.2",
    "@heroicons/react": "^2.2.0",
    "@mdx-js/esbuild": "^3.1.1",
    "@mhsdesign/jit-browser-tailwindcss": "0.3.0",
    "@onedoc/client": "^0.1.33",
    "@swc/core": "^1.15.33",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.9.1",
    "@types/postcss-css-variables": "^0.18.3",
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "@vitest/browser": "^1.6.1",
    "acorn": "^8.16.0",
    "acorn-typescript": "^1.4.13",
    "autoprefixer": "^10.5.0",
    "dotenv": "^16.6.1",
    "esbuild": "^0.28.0",
    "esbuild-plugin-alias": "^0.2.1",
    "front-matter": "^4.0.2",
    "glob": "^13.0.6",
    "mintlify": "4.0.122",
    "node-stdlib-browser": "^1.3.1",
    "patch-package": "^8.0.1",
    "pdf2pic": "^3.2.0",
    "postcss": "^8.5.15",
    "postcss-color-functional-notation": "^6.0.14",
    "postcss-css-variables": "^0.19.0",
    "postcss-logical": "^7.0.1",
    "pre-commit": "^1.2.2",
    "prettier": "^3.8.3",
    "qrcode.react": "^3.2.0",
    "react-docgen-typescript": "^2.4.0",
    "recharts": "^2.15.4",
    "remark-frontmatter": "^5.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1",
    "webdriverio": "^8.46.0"
  },
  "dependencies": {
    "@csstools/postcss-is-pseudo-class": "^4.0.8",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/server": "^11.11.0",
    "html-entities": "^2.6.0",
    "katex": "^0.17.0",
    "markdown-to-jsx": "^7.7.17",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "3.4.19"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.60.4"
  },
  "packageManager": "pnpm@11.2.2"
}
