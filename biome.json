{
	"$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": ["**", "!!**/dist"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"useNodejsImportProtocol": "off"
			},
			"complexity": {
				"noImportantStyles": "off"
			},
			"correctness": {
				"noUnknownProperty": {
					"level": "error",
					"options": {
						"ignore": [
							"string-set",
							"footnote-style-position",
							"-prince-flow",
							"-prince-pdf-form"
						]
					}
				},

				"noUnknownFunction": {
					"level": "error",
					"options": {
						"ignore": ["content", "flow", "running", "static", "string"]
					}
				}
			},
			"security": {
				"noDangerouslySetInnerHtml": "off"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
